        "dto.CreateUserRequest": {
            "type": "object",
            "required": [
                "fio",
                "telephone_number",
                "user_login",
                "user_password"
            ],
            "properties": {
                "city": {
                    "type": "string",
                    "maxLength": 50,
                    "example": "Saint Petersburg"
                },
                "fio": {
                    "type": "string",
                    "maxLength": 255,
                    "minLength": 1,
                    "example": "Петрова Мария Сергеевна"
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "active",
                        "blocked"
                    ],
                    "example": "active"
                },
                "telephone_number": {
                    "type": "string",
                    "maxLength": 20,
                    "minLength": 5,
                    "example": "+79998887766"
                },
                "user_description": {
                    "type": "string",
                    "maxLength": 1000,
                    "example": "Волонтёр приюта"
                },
                "user_login": {
                    "type": "string",
                    "maxLength": 50,
                    "minLength": 3,
                    "example": "maria_petrova"
                },
                "user_password": {
                    "type": "string",
                    "maxLength": 255,
                    "minLength": 6,
                    "example": "securepassword123"
                }
            }
        },
        "dto.GetPurchaseRequestResponse": {
            "type": "object",
            "properties": {
